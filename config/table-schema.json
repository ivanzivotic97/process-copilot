      "privileges": {
        "create": "UserOwned",
        "read": "UserOwned",
        "write": "UserOwned",
        "delete": "None",
        "append": "UserOwned",
        "appendTo": "UserOwned",
        "assign": "None",
        "share": "None"
      },
      "fieldLevelSecurity": [
        {
          "fieldName": "cr4ea_ai_summary",
          "readAccess": true,
          "updateAccess": false
        },
        {
          "fieldName": "cr4ea_ai_capa",
          "readAccess": true,
          "updateAccess": false
        },
        {
          "fieldName": "cr4ea_confidence",
          "readAccess": false,
          "updateAccess": false
        }
      ]
    },
    {
      "roleName": "Quality Manager",
      "privileges": {
        "create": "Organization",
        "read": "Organization",
        "write": "Organization",
        "delete": "Organization",
        "append": "Organization",
        "appendTo": "Organization",
        "assign": "Organization",
        "share": "Organization"
      },
      "fieldLevelSecurity": [
        {
          "fieldName": "cr4ea_ai_summary",
          "readAccess": true,
          "updateAccess": true
        },
        {
          "fieldName": "cr4ea_ai_capa",
          "readAccess": true,
          "updateAccess": true
        },
        {
          "fieldName": "cr4ea_confidence",
          "readAccess": true,
          "updateAccess": false
        }
      ]
    },
    {
      "roleName": "Quality Director",
      "privileges": {
        "create": "None",
        "read": "Organization",
        "write": "None",
        "delete": "None",
        "append": "None",
        "appendTo": "None",
        "assign": "None",
        "share": "None"
      },
      "fieldLevelSecurity": [
        {
          "fieldName": "cr4ea_ai_summary",
          "readAccess": true,
          "updateAccess": false
        },
        {
          "fieldName": "cr4ea_ai_capa",
          "readAccess": true,
          "updateAccess": false
        },
        {
          "fieldName": "cr4ea_confidence",
          "readAccess": true,
          "updateAccess": false
        }
      ]
    }
  ],
  "views": [
    {
      "viewName": "Active Deviations",
      "viewType": "Public",
      "isDefault": true,
      "columns": [
        "cr4ea_title",
        "cr4ea_severity",
        "cr4ea_status",
        "cr4ea_product_name",
        "cr4ea_batch_number",
        "cr4ea_deviation_date",
        "cr4ea_investigation_owner",
        "createdon"
      ],
      "filter": {
        "statecode": 0
      },
      "sortOrder": [
        {
          "column": "createdon",
          "direction": "descending"
        }
      ]
    },
    {
      "viewName": "High Severity Deviations",
      "viewType": "Public",
      "columns": [
        "cr4ea_title",
        "cr4ea_severity",
        "cr4ea_status",
        "cr4ea_product_name",
        "cr4ea_batch_number",
        "cr4ea_deviation_date",
        "cr4ea_investigation_owner",
        "cr4ea_confidence",
        "createdon"
      ],
      "filter": {
        "statecode": 0,
        "cr4ea_severity": 919860002
      },
      "sortOrder": [
        {
          "column": "createdon",
          "direction": "descending"
        }
      ]
    },
    {
      "viewName": "My Open Deviations",
      "viewType": "Public",
      "columns": [
        "cr4ea_title",
        "cr4ea_severity",
        "cr4ea_status",
        "cr4ea_product_name",
        "cr4ea_batch_number",
        "cr4ea_target_closure_date",
        "createdon"
      ],
      "filter": {
        "statecode": 0,
        "cr4ea_status": 919860000,
        "ownerid": "{current_user}"
      },
      "sortOrder": [
        {
          "column": "createdon",
          "direction": "ascending"
        }
      ]
    },
    {
      "viewName": "Deviations Requiring Review",
      "viewType": "Public",
      "columns": [
        "cr4ea_title",
        "cr4ea_severity",
        "cr4ea_status",
        "cr4ea_product_name",
        "cr4ea_batch_number",
        "cr4ea_investigation_owner",
        "cr4ea_target_closure_date",
        "createdon"
      ],
      "filter": {
        "statecode": 0,
        "cr4ea_status": 919860001
      },
      "sortOrder": [
        {
          "column": "createdon",
          "direction": "ascending"
        }
      ]
    },
    {
      "viewName": "Overdue Deviations",
      "viewType": "Public",
      "columns": [
        "cr4ea_title",
        "cr4ea_severity",
        "cr4ea_status",
        "cr4ea_product_name",
        "cr4ea_batch_number",
        "cr4ea_investigation_owner",
        "cr4ea_target_closure_date",
        "createdon"
      ],
      "filter": {
        "statecode": 0,
        "cr4ea_target_closure_date": "{less_than_today}",
        "cr4ea_status": [919860000, 919860001]
      },
      "sortOrder": [
        {
          "column": "cr4ea_target_closure_date",
          "direction": "ascending"
        }
      ]
    }
  ],
  "forms": [
    {
      "formName": "Deviation Main Form",
      "formType": "Main",
      "sections": [
        {
          "sectionName": "Deviation Details",
          "columns": 2,
          "fields": [
            "cr4ea_title",
            "cr4ea_description",
            "cr4ea_product_name",
            "cr4ea_batch_number",
            "cr4ea_equipment_id",
            "cr4ea_deviation_date",
            "cr4ea_status",
            "cr4ea_investigation_owner"
          ]
        },
        {
          "sectionName": "AI Analysis",
          "columns": 1,
          "fields": [
            "cr4ea_severity",
            "cr4ea_confidence",
            "cr4ea_classified_date",
            "cr4ea_ai_summary",
            "cr4ea_ai_capa"
          ],
          "fieldSettings": [
            {
              "fieldName": "cr4ea_ai_summary",
              "readOnly": true
            },
            {
              "fieldName": "cr4ea_ai_capa",
              "readOnly": true
            }
          ]
        },
        {
          "sectionName": "Investigation",
          "columns": 1,
          "fields": [
            "cr4ea_root_cause",
            "cr4ea_capa_implemented",
            "cr4ea_effectiveness_verified",
            "cr4ea_target_closure_date",
            "cr4ea_actual_closure_date"
          ]
        },
        {
          "sectionName": "Batch Disposition",
          "columns": 2,
          "fields": [
            "cr4ea_batch_disposition",
            "cr4ea_regulatory_reportable"
          ]
        }
      ]
    }
  ],
  "businessRules": [
    {
      "ruleName": "Set Target Closure Date",
      "scope": "Entity",
      "trigger": "OnCreate",
      "conditions": [
        {
          "field": "cr4ea_severity",
          "operator": "Equals",
          "value": 919860002
        }
      ],
      "actions": [
        {
          "type": "SetFieldValue",
          "field": "cr4ea_target_closure_date",
          "value": "{createdon + 30 days}"
        }
      ]
    },
    {
      "ruleName": "Require Investigation Owner for Under Investigation Status",
      "scope": "Entity",
      "trigger": "OnSave",
      "conditions": [
        {
          "field": "cr4ea_status",
          "operator": "Equals",
          "value": 919860001
        },
        {
          "field": "cr4ea_investigation_owner",
          "operator": "DoesNotContainData"
        }
      ],
      "actions": [
        {
          "type": "ShowErrorMessage",
          "message": "Investigation Owner is required when Status is set to 'Under Investigation'"
        }
      ]
    },
    {
      "ruleName": "Set Actual Closure Date When Closed",
      "scope": "Entity",
      "trigger": "OnSave",
      "conditions": [
        {
          "field": "cr4ea_status",
          "operator": "Equals",
          "value": 919860002
        },
        {
          "field": "cr4ea_actual_closure_date",
          "operator": "DoesNotContainData"
        }
      ],
      "actions": [
        {
          "type": "SetFieldValue",
          "field": "cr4ea_actual_closure_date",
          "value": "{today}"
        }
      ]
    }
  ],
  "notes": [
    "This schema represents the Dataverse table configuration for Process Copilot deviation management",
    "Choice field numeric values (e.g., 919860000) are auto-generated by Dataverse; customize as needed",
    "Field-level security on AI output fields ensures quality specialists can view but not edit AI-generated content",
    "Audit and change tracking enabled for regulatory compliance (21 CFR Part 11)",
    "Additional custom columns can be added based on site-specific requirements (e.g., manufacturing location, department)",
    "Integration with external QMS systems can be achieved via Dataverse Web API (REST/OData)"
  ]
}
